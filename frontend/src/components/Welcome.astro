---
import { Image } from "astro:assets";
import avatar from "../assets/avatar.jpg";
---

<div class="flex justify-center px-4 py-8">
  <div class="w-full max-w-sm rounded-xl border border-gray-200 bg-white p-6 text-center shadow-sm">
    <Image
      src={avatar}
      alt="James Pilkington"
      width={112}
      height={112}
      densities={[1, 2]}
      loading="eager"
      decoding="async"
      fetchpriority="high"
      class="mx-auto h-28 w-28 rounded-full object-cover"
    />
    <p class="mt-4 text-lg font-semibold text-gray-900">James Pilkington</p>
  </div>
</div>
