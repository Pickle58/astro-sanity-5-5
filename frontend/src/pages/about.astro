---
import Layout from "../layouts/Layout.astro";

const skills = [
  "AI aided development",
  "TypeScript & JavaScript",
  "HTML & semantic markup",
  "CSS, Tailwind CSS & responsive layouts",
  "Astro & static site architecture",
  "React patterns & component design",
  "REST APIs & data fetching",
  "Git & collaborative workflows",
  "Accessibility & performance basics",
];

const interests = [
  "Web Design and Development",
  "AI-aided coding",
  "Kayaking",
  "Hiking",
  "Riding ATVs",
  "Music",
  "Listening to Old Time Radio",
  "Cooking",
];

const avatarSrc = "/avatar.jpg";
const avatarAlt = "Portrait photo";
---

<Layout title="About — Pilkington Enterprises" description="About Pilkington Enterprises.">
  <section class="mt-6 sm:mt-8">
    <div
      class="mx-auto grid w-full max-w-5xl grid-cols-1 gap-4 lg:grid-cols-3 lg:gap-5 lg:items-start"
    >
      <!-- Grid: stacked by default; 3 cols from lg (skills, interests, image) -->
      <div
        class="col-start-1 row-start-1 w-full min-w-0 rounded-xl border-2 border-gray-300 bg-white p-4 shadow-lg ring-1 ring-black/10 sm:rounded-2xl sm:p-5 sm:shadow-xl lg:col-start-1 lg:row-start-1"
      >
        <h2 class="m-0 mb-3 font-sans text-lg font-bold tracking-tight text-black">Skills</h2>
        <ul class="m-0 list-disc space-y-1.5 pl-4 font-sans text-sm leading-snug text-slate-800">
          {skills.map((skill) => <li>{skill}</li>)}
        </ul>
      </div>

      <div
        class="col-start-1 row-start-2 w-full min-w-0 rounded-xl border-2 border-gray-300 bg-white p-4 shadow-lg ring-1 ring-black/10 sm:rounded-2xl sm:p-5 sm:shadow-xl lg:col-start-2 lg:row-start-1"
      >
        <h2 class="m-0 mb-3 font-sans text-lg font-bold tracking-tight text-black">My Interests</h2>
        <ul class="m-0 space-y-1 pl-0 font-sans text-sm leading-snug text-slate-800">
          {interests.map((interest) => (
            <li class="flex items-start gap-2">
              <span class="mt-1.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-indigo-500" aria-hidden="true"></span>
              <span>{interest}</span>
            </li>
          ))}
        </ul>
      </div>

      <div
        class="col-start-1 row-start-3 w-full min-w-0 rounded-xl border-2 border-gray-300 bg-white p-4 shadow-lg ring-1 ring-black/10 sm:rounded-2xl sm:p-5 sm:shadow-xl lg:col-start-3 lg:row-start-1 lg:flex lg:justify-end"
      >
        <img
          src={avatarSrc}
          alt={avatarAlt}
          width={512}
          height={512}
          class="mx-auto aspect-square h-auto max-h-52 max-w-52 rounded-lg object-cover lg:mx-0 lg:ml-auto"
          loading="lazy"
          decoding="async"
        />
      </div>
    </div>
  </section>
</Layout>
