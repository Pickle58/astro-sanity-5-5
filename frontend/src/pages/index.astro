---
import Card from "../components/Card.astro";
import Welcome from "../components/Welcome.astro";
import Layout from "../layouts/Layout.astro";
import { getPosts } from "../utils/sanity";


const posts = await getPosts();
---

<Layout
  title="Pilkington Enterprises"
  description="A Site devoted to Pilkington Enterprises."
>
  <section class="mt-6 flex flex-col gap-5 sm:mt-8 sm:gap-6">
    {posts.length ? posts.map((post) => <Card post={post} />) : <Welcome />}
  </section>
</Layout>
