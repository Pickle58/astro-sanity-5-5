# Required - The ID of your Sanity project
PUBLIC_SANITY_STUDIO_PROJECT_ID=""
# Required - The dataset of your Sanity project
PUBLIC_SANITY_STUDIO_DATASET=""
# Required - The generated read token, used to fetch data on the server
SANITY_API_READ_TOKEN=""
# Required for authenticated comment writes
SANITY_API_WRITE_TOKEN=""
# Optional - The URL of your Sanity Studio. Defaults to http://localhost:3333
PUBLIC_SANITY_STUDIO_URL=""
# Optional - Visual Editing - set to "true" to enable overlays in Presentation tool
PUBLIC_SANITY_VISUAL_EDITING_ENABLED="false"
# Optional - Comma-separated emails that auto-publish comments
TRUSTED_COMMENTER_EMAILS=""

# Clerk publishable key (Astro)
PUBLIC_CLERK_PUBLISHABLE_KEY=""
# Clerk secret key (server-only) — required or dev server errors and login/session breaks
CLERK_SECRET_KEY=""
# Optional — defaults are set in astro.config ("/sign-in", "/sign-up"); add these exact URLs under
# Clerk Dashboard → Paths → Redirect / component URLs for http://localhost:4321 when developing.

# Required - Resend API key for the contact form (https://resend.com/api-keys)
RESEND_API_KEY=""
# Required - Sender for the contact form. Use a domain verified in Resend.
# Format: "Display Name <local-part@verified-domain.com>"
RESEND_FROM_ADDRESS=""
# Required - Email address that receives contact form notifications.
RESEND_NOTIFY_TO=""
